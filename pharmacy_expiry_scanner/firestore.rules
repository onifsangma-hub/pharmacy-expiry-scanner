// firestore.rules
// Place this file in your Firebase project root.
// Deploy with: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // pharmacy_items collection and subcollections.
    // Only authenticated (signed-in) users can read or write.
    match /pharmacy_items/{barcode} {
      allow read, write: if request.auth != null;

      // All subcollections (batches AND history, plus any future ones).
      // Firestore rules do NOT cascade into subcollections, so a recursive
      // match is required — without it, every write to
      // pharmacy_items/{barcode}/history/{historyId} would be DENIED.
      match /{document=**} {
        allow read, write: if request.auth != null;
      }
    }

    // Top-level sale records generated by FEFO sales deductions.
    match /sales/{saleId} {
      allow read, write: if request.auth != null;
    }

    // Dashboard summary updated after receiving, sales, and adjustments.
    match /summaries/{summaryId} {
      allow read, write: if request.auth != null;
    }
  }
}

// ──────────────────────────────────────────────────────────────────────────────
// Auth is now enforced: every read/write requires a signed-in user
// (request.auth != null). Enable Email/Password sign-in in the Firebase
// console: Authentication > Sign-in method > Email/Password > Enable.
//
// FURTHER HARDENING (optional): scope access per user/role, or validate
// that history rows carry the caller's uid, e.g.:
//   allow create: if request.auth != null
//                 && request.resource.data.userId == request.auth.uid;
// ──────────────────────────────────────────────────────────────────────────────
